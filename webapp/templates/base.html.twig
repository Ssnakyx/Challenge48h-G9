<!DOCTYPE html>
<html class="light" lang="en">
    <head>
        <meta charset="UTF-8">
        <meta content="width=device-width, initial-scale=1.0" name="viewport">
        <title>{% block title %}AirMetrics | Environmental Narrative{% endblock %}</title>
        <!-- Fonts -->
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
        <!-- Icons -->
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
        <!-- Leaflet CSS -->
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
        <!-- Tailwind CDN -->
        <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
        <script>
            tailwind.config = {
                darkMode: "class",
                theme: {
                    extend: {
                        colors: {
                            "primary": "#004d64",
                            "on-secondary-container": "#526772",
                            "on-primary-fixed": "#001f2a",
                            "secondary-fixed": "#cfe6f2",
                            "inverse-surface": "#2c3134",
                            "on-tertiary-fixed-variant": "#005049",
                            "on-surface-variant": "#3f484d",
                            "surface-container-low": "#f0f4f7",
                            "secondary-container": "#cfe6f2",
                            "inverse-primary": "#87d0f2",
                            "surface-container": "#eaeef2",
                            "error-container": "#ffdad6",
                            "surface-container-high": "#e4e9ec",
                            "primary-fixed": "#bee9ff",
                            "tertiary-container": "#006a62",
                            "on-primary": "#ffffff",
                            "on-secondary": "#ffffff",
                            "surface-container-highest": "#dfe3e6",
                            "primary-fixed-dim": "#87d0f2",
                            "surface-container-lowest": "#ffffff",
                            "outline": "#70787e",
                            "surface-variant": "#dfe3e6",
                            "tertiary": "#005049",
                            "on-tertiary": "#ffffff",
                            "on-background": "#171c1f",
                            "surface-bright": "#f6fafd",
                            "inverse-on-surface": "#edf1f5",
                            "surface": "#f6fafd",
                            "outline-variant": "#bfc8cd",
                            "on-error-container": "#93000a",
                            "tertiary-fixed": "#84f5e8",
                            "tertiary-fixed-dim": "#66d9cc",
                            "on-error": "#ffffff",
                            "secondary": "#4c616b",
                            "on-primary-container": "#a2e1ff",
                            "primary-container": "#006684",
                            "background": "#f6fafd",
                            "on-surface": "#171c1f",
                            "surface-tint": "#016684",
                            "on-tertiary-fixed": "#00201d",
                            "secondary-fixed-dim": "#b4cad5",
                            "on-secondary-fixed-variant": "#354a53",
                            "on-tertiary-container": "#79ebdd",
                            "on-primary-fixed-variant": "#004d64",
                            "error": "#ba1a1a",
                            "surface-dim": "#d6dbde",
                        },
                        fontFamily: {
                            "headline": ["Manrope"],
                            "body": ["Inter"],
                            "label": ["Inter"]
                        },
                        borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                    },
                },
            }
        </script>
        <style>
            .material-symbols-outlined {
                font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            }
            .glass-panel {
                background: rgba(246, 250, 253, 0.7);
                backdrop-filter: blur(12px);
            }
            .custom-scrollbar::-webkit-scrollbar {
                width: 4px;
            }
            .custom-scrollbar::-webkit-scrollbar-thumb {
                background: #bfc8cd;
                border-radius: 10px;
            }
            body {
                min-height: max(884px, 100dvh);
            }
        </style>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <!-- Leaflet JS -->
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    </head>
    <body class="bg-surface text-on-surface font-body overflow-x-hidden selection:bg-primary-fixed">
        {% block body %}{% endblock %}
    </body>
</html>
