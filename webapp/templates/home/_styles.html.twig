<style>
    :root {
        --teal-950: #011a17;
        --teal-900: #052e28;
        --teal-800: #0a4a3e;
        --teal-600: #0d6b5a;
        --teal-400: #1ab394;
        --teal-200: #7de2cf;
        --teal-100: #c0f3ea;
        --amber-400: #fbbf24;
        --rose-500: #f43f5e;
        --slate-900: #0f172a;
        --slate-800: #1e293b;
        --slate-700: #334155;
        --glass-bg: rgba(255,255,255,0.04);
        --glass-border: rgba(255,255,255,0.08);
    }

    * { box-sizing: border-box; }

    html, body {
        margin: 0; padding: 0;
        background: var(--teal-950);
        color: #e2f8f4;
        font-family: 'Cabinet Grotesk', sans-serif;
        overflow-x: hidden;
    }

    /* ── Ambient background ── */
    #ambient-bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
    }
    .mesh-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        opacity: 0.18;
        animation: blobDrift 18s ease-in-out infinite;
    }
    .mesh-blob:nth-child(1) { width: 700px; height: 700px; background: radial-gradient(circle, #1ab394, #052e28); top: -200px; left: -200px; animation-delay: 0s; }
    .mesh-blob:nth-child(2) { width: 500px; height: 500px; background: radial-gradient(circle, #0d6b5a, #011a17); bottom: -100px; right: -100px; animation-delay: -6s; }
    .mesh-blob:nth-child(3) { width: 350px; height: 350px; background: radial-gradient(circle, #7de2cf, #0a4a3e); top: 40%; left: 40%; animation-delay: -12s; }

    @keyframes blobDrift {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(40px, -30px) scale(1.05); }
        66% { transform: translate(-20px, 50px) scale(0.95); }
    }

    /* ── Particle canvas ── */
    #particle-canvas {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.5;
    }

    /* ── Noise grain overlay ── */
    body::after {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }

    /* ── TopAppBar ── */
    header {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        padding: 0 2rem;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: linear-gradient(to bottom, rgba(1,26,23,0.92), transparent);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--glass-border);
    }
    .logo-mark {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .logo-icon {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, var(--teal-600), var(--teal-400));
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 0 20px rgba(26,179,148,0.4);
    }
    .logo-title {
        font-family: 'Clash Display', sans-serif;
        font-weight: 700;
        font-size: 1.35rem;
        letter-spacing: -0.04em;
        color: var(--teal-100);
        text-shadow: 0 0 30px rgba(26,179,148,0.3);
    }
    .logo-badge {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.15em;
        color: var(--teal-400);
        text-transform: uppercase;
        background: rgba(26,179,148,0.1);
        border: 1px solid rgba(26,179,148,0.2);
        padding: 2px 8px;
        border-radius: 20px;
    }
    .header-actions { display: flex; gap: 8px; }
    .icon-btn {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: var(--teal-200);
        transition: background 0.2s, box-shadow 0.2s, transform 0.15s;
    }
    .icon-btn:hover {
        background: rgba(26,179,148,0.1);
        box-shadow: 0 0 12px rgba(26,179,148,0.2);
        transform: translateY(-1px);
    }

    main {
        position: relative;
        z-index: 2;
        padding-top: 64px;
    }

    /* ── Hero ── */
    .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 80px 24px 60px;
        position: relative;
        overflow: hidden;
    }
    .hero-eyebrow {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--teal-400);
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: fadeSlideUp 0.8s ease both 0.1s;
    }
    .hero-eyebrow::before, .hero-eyebrow::after {
        content: '';
        display: block;
        width: 40px; height: 1px;
        background: linear-gradient(to right, transparent, var(--teal-400));
    }
    .hero-eyebrow::after { background: linear-gradient(to left, transparent, var(--teal-400)); }
    .hero-title {
        font-family: 'Clash Display', sans-serif;
        font-weight: 700;
        font-size: clamp(3.5rem, 9vw, 7rem);
        line-height: 0.95;
        letter-spacing: -0.04em;
        color: var(--teal-100);
        margin-bottom: 28px;
        animation: fadeSlideUp 0.8s ease both 0.2s;
    }
    .hero-title .accent {
        display: inline-block;
        background: linear-gradient(135deg, var(--teal-400) 0%, var(--teal-200) 50%, #7de2cf 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
    }
    .hero-title .accent::after {
        content: '';
        position: absolute;
        bottom: 4px; left: 0; right: 0; height: 3px;
        background: linear-gradient(90deg, var(--teal-400), var(--teal-200));
        border-radius: 2px;
        opacity: 0.4;
    }
    .hero-sub {
        font-size: 1.1rem;
        color: rgba(192,243,234,0.6);
        max-width: 480px;
        margin: 0 auto 48px;
        line-height: 1.7;
        animation: fadeSlideUp 0.8s ease both 0.35s;
    }
    .hero-cta-group {
        display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
        animation: fadeSlideUp 0.8s ease both 0.5s;
    }
    .btn-primary {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 14px 32px;
        background: linear-gradient(135deg, var(--teal-600), var(--teal-400));
        color: #011a17;
        font-family: 'Cabinet Grotesk', sans-serif;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: -0.01em;
        border-radius: 100px;
        text-decoration: none;
        box-shadow: 0 8px 32px rgba(26,179,148,0.35), 0 0 0 1px rgba(26,179,148,0.2);
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 16px 48px rgba(26,179,148,0.45), 0 0 0 1px rgba(26,179,148,0.3);
    }
    .btn-secondary {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 14px 28px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        color: var(--teal-200);
        font-family: 'Cabinet Grotesk', sans-serif;
        font-weight: 700;
        font-size: 0.9rem;
        border-radius: 100px;
        text-decoration: none;
        backdrop-filter: blur(8px);
        transition: background 0.2s, border-color 0.2s, transform 0.2s;
    }
    .btn-secondary:hover {
        background: rgba(26,179,148,0.08);
        border-color: rgba(26,179,148,0.3);
        transform: translateY(-2px);
    }

    /* Floating data-cards in hero */
    .hero-float-card {
        position: absolute;
        background: rgba(10, 74, 62, 0.55);
        border: 1px solid rgba(26,179,148,0.2);
        backdrop-filter: blur(12px);
        border-radius: 16px;
        padding: 12px 18px;
        display: flex; align-items: center; gap: 10px;
        font-family: 'DM Mono', monospace;
        font-size: 11px;
        color: var(--teal-200);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        animation: floatCard 6s ease-in-out infinite;
        pointer-events: none;
    }
    .hero-float-card .dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        animation: pulseDot 2s ease infinite;
    }
    .hero-float-card:nth-child(1) { top: 22%; left: 8%; animation-delay: 0s; }
    .hero-float-card:nth-child(2) { top: 30%; right: 8%; animation-delay: -2s; }
    .hero-float-card:nth-child(3) { bottom: 25%; left: 12%; animation-delay: -4s; }

    @keyframes floatCard {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
    }
    @keyframes pulseDot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
    }
    @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Stats strip */
    .stats-strip {
        display: flex;
        justify-content: center;
        gap: 1px;
        background: rgba(255,255,255,0.05);
        border-top: 1px solid var(--glass-border);
        border-bottom: 1px solid var(--glass-border);
        overflow: hidden;
    }
    .stat-item {
        flex: 1;
        max-width: 200px;
        padding: 24px 20px;
        text-align: center;
        background: var(--glass-bg);
        transition: background 0.25s;
    }
    .stat-item:hover { background: rgba(26,179,148,0.06); }
    .stat-value {
        font-family: 'Clash Display', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--teal-200);
        letter-spacing: -0.04em;
        line-height: 1;
    }
    .stat-label {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(192,243,234,0.4);
        margin-top: 6px;
    }

    /* ── Map section ── */
    .section-eyebrow {
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--teal-400);
        margin-bottom: 8px;
    }
    .section-title {
        font-family: 'Clash Display', sans-serif;
        font-size: 2.2rem;
        font-weight: 700;
        color: var(--teal-100);
        letter-spacing: -0.04em;
        line-height: 1.1;
    }
    .filter-pill-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .filter-pill {
        padding: 7px 16px;
        border-radius: 100px;
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        color: rgba(192,243,234,0.6);
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        cursor: pointer;
        transition: all 0.2s;
    }
    .filter-pill.active, .filter-pill:hover {
        background: rgba(26,179,148,0.12);
        border-color: rgba(26,179,148,0.4);
        color: var(--teal-200);
        box-shadow: 0 0 12px rgba(26,179,148,0.15);
    }

    /* ── Resizable map container ── */
    .map-wrapper {
        position: relative;
        max-width: 900px;
        margin: 0 auto;
        border-radius: 24px;
        overflow: hidden;
        border: 1px solid rgba(26,179,148,0.15);
        box-shadow: 0 0 0 1px rgba(255,255,255,0.04), 0 32px 80px rgba(0,0,0,0.5), 0 0 60px rgba(26,179,148,0.08);
        animation: mapReveal 0.9s cubic-bezier(0.22,1,0.36,1) both 0.3s;
        resize: vertical;
        min-height: 360px;
        max-height: 85vh;
        height: 520px;
    }
    @keyframes mapReveal {
        from { opacity: 0; transform: translateY(40px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    .map-topbar {
        position: absolute;
        top: 16px; left: 16px; right: 16px;
        z-index: 20;
        display: flex;
        justify-content: space-between;
        align-items: center;
        pointer-events: none;
    }
    .map-topbar > * { pointer-events: all; }
    .map-status-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        background: rgba(1,26,23,0.75);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(26,179,148,0.25);
        border-radius: 100px;
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        letter-spacing: 0.12em;
        color: var(--teal-200);
        text-transform: uppercase;
    }
    .live-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--teal-400);
        box-shadow: 0 0 8px var(--teal-400);
        animation: pulseDot 1.5s ease infinite;
    }
    .map-controls {
        display: flex;
        gap: 6px;
    }
    .map-ctrl-btn {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: rgba(1,26,23,0.8);
        border: 1px solid rgba(26,179,148,0.2);
        backdrop-filter: blur(10px);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: var(--teal-200);
        font-size: 18px;
        font-weight: 700;
        transition: background 0.2s, transform 0.15s;
        user-select: none;
    }
    .map-ctrl-btn:hover {
        background: rgba(26,179,148,0.15);
        transform: scale(1.05);
    }

    .resize-hint {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 30;
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.12em;
        color: rgba(192,243,234,0.35);
        text-transform: uppercase;
        pointer-events: none;
        transition: opacity 0.3s;
    }
    .resize-hint .grip-icon {
        width: 24px; height: 8px;
        display: flex; flex-direction: column;
        gap: 3px; align-items: center; justify-content: center;
    }
    .resize-hint .grip-icon span {
        display: block;
        width: 20px; height: 2px;
        background: rgba(26,179,148,0.35);
        border-radius: 2px;
    }
    .map-wrapper:hover .resize-hint { opacity: 1; }

    #leaflet-map {
        width: 100%;
        height: 100%;
        z-index: 0;
        background: var(--teal-950);
    }
    .leaflet-pane { z-index: 1 !important; }
    .leaflet-top, .leaflet-bottom { z-index: 5 !important; }
    .leaflet-control-zoom { display: none !important; }
    .leaflet-control-attribution { font-size: 9px !important; opacity: 0.4; background: transparent !important; color: var(--teal-400) !important; }

    /* ── Detail slide-out panel ── */
    .slide-panel {
        transform: translateX(calc(100% + 32px));
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
        opacity: 0;
    }
    .slide-panel.open {
        transform: translateX(0);
        opacity: 1;
    }
    #detail-panel {
        position: fixed;
        right: 0; top: 0;
        height: 100%;
        width: 100%;
        max-width: 400px;
        background: var(--teal-950);
        background-image:
            radial-gradient(ellipse at 20% 20%, rgba(26,179,148,0.08) 0%, transparent 60%),
            radial-gradient(ellipse at 80% 80%, rgba(10,74,62,0.3) 0%, transparent 60%);
        z-index: 200;
        border-left: 1px solid rgba(26,179,148,0.12);
        box-shadow: -32px 0 80px rgba(0,0,0,0.6);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }
    #detail-panel::-webkit-scrollbar { width: 4px; }
    #detail-panel::-webkit-scrollbar-track { background: transparent; }
    #detail-panel::-webkit-scrollbar-thumb { background: rgba(26,179,148,0.3); border-radius: 2px; }

    .panel-inner { padding: 32px 28px; }
    .panel-eyebrow {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--teal-400);
        margin-bottom: 4px;
    }
    .panel-station-name {
        font-family: 'Clash Display', sans-serif;
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--teal-100);
        letter-spacing: -0.04em;
        line-height: 1.1;
    }
    .panel-close {
        width: 34px; height: 34px;
        border-radius: 10px;
        background: rgba(26,179,148,0.07);
        border: 1px solid rgba(26,179,148,0.15);
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        color: var(--teal-200);
        transition: background 0.2s, transform 0.15s;
    }
    .panel-close:hover { background: rgba(244,63,94,0.12); color: #f43f5e; transform: scale(1.05); }

    /* AQI Gauge */
    .aqi-gauge-wrap {
        background: linear-gradient(135deg, rgba(10,74,62,0.4), rgba(5,46,40,0.6));
        border: 1px solid rgba(26,179,148,0.12);
        border-radius: 20px;
        padding: 32px 24px;
        text-align: center;
        margin: 24px 0;
        position: relative;
        overflow: hidden;
    }
    .aqi-gauge-wrap::before {
        content: '';
        position: absolute;
        top: -60px; left: -60px;
        width: 180px; height: 180px;
        background: radial-gradient(circle, rgba(26,179,148,0.1), transparent);
        border-radius: 50%;
    }
    .aqi-value-label {
        font-family: 'Clash Display', sans-serif;
        font-size: 4rem;
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 1;
        color: var(--teal-100);
    }
    .aqi-status-label {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-top: 4px;
        margin-bottom: 16px;
    }
    .aqi-desc {
        font-size: 0.82rem;
        color: rgba(192,243,234,0.5);
        line-height: 1.6;
    }
    .aqi-bar-track {
        height: 6px;
        background: rgba(255,255,255,0.06);
        border-radius: 3px;
        margin: 16px 0 8px;
        overflow: hidden;
    }
    .aqi-bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.8s cubic-bezier(0.22,1,0.36,1), background 0.5s;
    }

    /* Weather grid */
    .weather-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 24px;
    }
    .weather-card {
        background: rgba(10,74,62,0.3);
        border: 1px solid rgba(26,179,148,0.1);
        border-radius: 14px;
        padding: 14px 10px;
        text-align: center;
        transition: background 0.2s, border-color 0.2s;
    }
    .weather-card:hover {
        background: rgba(26,179,148,0.1);
        border-color: rgba(26,179,148,0.25);
    }
    .weather-icon { font-size: 20px; color: var(--teal-400); margin-bottom: 6px; }
    .weather-value { font-family: 'Clash Display', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--teal-100); }
    .weather-key {
        font-family: 'DM Mono', monospace;
        font-size: 8px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(192,243,234,0.35);
        margin-top: 2px;
    }

    /* Pollutant rows */
    .section-label {
        font-family: 'DM Mono', monospace;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(192,243,234,0.35);
        margin-bottom: 12px;
    }
    .pollutant-row {
        background: rgba(10,74,62,0.25);
        border: 1px solid rgba(26,179,148,0.08);
        border-radius: 14px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
        transition: background 0.2s, border-color 0.2s;
    }
    .pollutant-row:hover {
        background: rgba(26,179,148,0.08);
        border-color: rgba(26,179,148,0.2);
    }
    .pollutant-badge {
        width: 34px; height: 34px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-family: 'DM Mono', monospace;
        font-size: 10px;
        font-weight: 500;
    }
    .pollutant-name { font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.9rem; font-weight: 700; color: var(--teal-100); }
    .pollutant-type { font-family: 'DM Mono', monospace; font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(192,243,234,0.35); }
    .pollutant-val { font-family: 'Clash Display', sans-serif; font-size: 1.1rem; font-weight: 700; color: var(--teal-100); }
    .pollutant-unit { font-family: 'DM Mono', monospace; font-size: 9px; color: rgba(192,243,234,0.35); }

    .btn-history {
        display: flex; align-items: center; justify-content: center; gap: 8px;
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, var(--teal-800), var(--teal-600));
        border: 1px solid rgba(26,179,148,0.25);
        border-radius: 14px;
        color: var(--teal-100);
