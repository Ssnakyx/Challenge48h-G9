# ============================================================================
# PostgreSQL Credentials & Replication
# ============================================================================
POSTGRES_USER=app_user
POSTGRES_PASSWORD=SuperSecretPassword123!
POSTGRES_DB=challenge_db
POSTGRES_REPLICATION_USER=repl_user
POSTGRES_REPLICATION_PASSWORD=ReplSecretPassword456!

# ============================================================================
# Application Environment & Secrets
# ============================================================================
APP_ENV=prod
APP_SECRET=UnSecretSymfonyTresLongEtTresComplique
MAILER_DSN=null://null

# ============================================================================
# Data Service Configuration (Python FastAPI)
# ============================================================================
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db-master:5432/${POSTGRES_DB}?serverVersion=15&charset=utf8
POLLUTION_BUCKET=https://object.data.gouv.fr/ineris-prod
POLLUTION_PREFIX=lcsqa/concentrations-de-polluants-atmospheriques-reglementes/temps-reel/
POLLUTION_METADATA_URL=https://static.data.gouv.fr/resources/donnees-temps-reel-de-mesure-des-concentrations-de-polluants-atmospheriques-reglementes-1/20251210-084445/fr-2025-d-lcsqa-ineris-20251209.xls
WEATHER_RESOURCE_URL=https://object.files.data.gouv.fr/meteofrance/data/synchro_ftp/OBS/SYNOP/synop_2024.csv.gz
MAX_DISTANCE_KM=75
FORECAST_HORIZON_HOURS=6
REALTIME_WINDOW_HOURS=24
MAX_HISTORY_DAYS=15

# ============================================================================
# Data API Service Configuration
# ============================================================================
DATA_API_BASE_URL=http://data-api:80
